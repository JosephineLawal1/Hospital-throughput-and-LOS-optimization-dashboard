import pandas as pd
from src.workload_metrics import provider_workload, department_workload
from src.continuity_metrics import continuity_scores, high_utilizers

df = pd.read_csv('../data/patient_encounters_clean.csv')

prov_workload = provider_workload(df)
dept_workload = department_workload(df)
cont_df = continuity_scores(df)
high_util_df = high_utilizers(df)

# Example: merge continuity with basic patient info
patient_demo = df[['patient_id', 'gender', 'age', 'race']].drop_duplicates()
cont_with_demo = cont_df.merge(patient_demo, on='patient_id', how='left')

cont_with_demo.to_csv('../data/dashboard_continuity.csv', index=False)
prov_workload.to_csv('../data/dashboard_provider_workload.csv', index=False)
dept_workload.to_csv('../data/dashboard_department_workload.csv', index=False)
high_util_df.to_csv('../data/dashboard_high_utilizers.csv', index=False)
